{
  "_version": "1.82.0",
  "sap.app": {
    "id": "com.demo.learnui5",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.20.4",
      "toolsId": "0f2291d0-0a66-42de-a97d-f7321c9946c5"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZMN_EMP_SRV/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.demo.learnui5.i18n.i18n"
        }
      },
      "oModel": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      },
      "empModel": {
        "type": "sap.ui.model.json.JSONModel"
      },
      "lookUpModel": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/lookupvalues.json"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.demo.learnui5.view",
        "async": true,
        "viewPath": "com.demo.learnui5.view"
      },
      "routes": [
        {
          "name": "RouteView1",
          "pattern": ":?query:",
          "target": [
            "TargetView1"
          ]
        },
        {
          "name": "RouteView2",
          "pattern": "Secondview",
          "target": [
            "TargetView2"
          ]
        },
        {
          "name": "RouteView3",
          "pattern": "Thirdview",
          "target": [
            "TargetView3"
          ]
        },
        {
          "name": "RouteView4",
          "pattern": "Fourthview",
          "target": [
            "TargetView4"
          ]
        },
        {
          "name": "RouteView5",
          "pattern": "Fifthview",
          "target": [
            "TargetView5"
          ]
        }
      ],
      "targets": {
        "TargetView1": {
          "id": "View1",
          "name": "View1"
        },
        "TargetView2": {
          "id": "View2",
          "name": "View2"
        },
        "TargetView3": {
          "id": "View3",
          "name": "View3"
        },
        "TargetView4": {
          "id": "View4",
          "name": "View4"
        },
        "TargetView5": {
          "id": "View5",
          "name": "View5"
        }
      }
    },
    "rootView": {
      "viewName": "com.demo.learnui5.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}