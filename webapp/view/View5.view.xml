<mvc:View
    controllerName="com.demo.learnui5.controller.View5"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Page
        title="i am View 5"
        showNavButton="true"
        navButtonPress="onNavBack"
    >
        <Panel headerText="onPressRow" expand="true" expandable="true">
            <content>
                <Table items="{oModel>/EmployeeSet}">
                    <headerToolbar />
                    <columns>
                        <Column>
                            <Text text="Employee ID" />
                        </Column>
                        <Column>
                            <Text text="Employee Name" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation" press="onPressRow">
                            <Text text="{oModel>Empid}" />
                            <Text text="{oModel>Name}" />
                        </ColumnListItem>
                    </items>
                </Table>
            </content>
        </Panel>
        <Panel headerText="SingleSelectMaster" expand="true" expandable="true">
            <content>
                <Table id="oTabEmp" items="{oModel>/EmployeeSet}"  mode="SingleSelectMaster">
                    <headerToolbar>
                    <Toolbar >
                    <ToolbarSpacer ></ToolbarSpacer>
                    <Button text="Get Selected Employee ID" press="onGetEmployee"></Button>
                    </Toolbar>
                    </headerToolbar>
                    <columns>
                        <Column>
                            <Text text="Employee ID" />
                        </Column>
                        <Column>
                            <Text text="Employee Name" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation">
                            <Text text="{oModel>Empid}" />
                            <Text text="{oModel>Name}" />
                        </ColumnListItem>
                    </items>
                </Table>
            </content>
        </Panel>
        <Panel headerText="MultiSelectMaster" expand="true" expandable="true">
            <content>
                <Table id="oMultiTabEmp" items="{oModel>/EmployeeSet}"  mode="MultiSelect">
                    <headerToolbar>
                    <Toolbar >
                    <ToolbarSpacer ></ToolbarSpacer>
                    <Button text="Get Selected Employee ID" press="onGetMultiEmp"></Button>
                    </Toolbar>
                    </headerToolbar>
                    <columns>
                        <Column>
                            <Text text="Employee ID" />
                        </Column>
                        <Column>
                            <Text text="Employee Name" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation">
                            <Text text="{oModel>Empid}" />
                            <Text text="{oModel>Name}" />
                        </ColumnListItem>
                    </items>
                </Table>
            </content>
        </Panel>
        <footer>
        <Bar>
        <contentRight>
        <Button text="Next Page" press="nextPage" type="Emphasized"></Button>
        </contentRight>   
        </Bar>
        </footer>
    </Page>
</mvc:View>
