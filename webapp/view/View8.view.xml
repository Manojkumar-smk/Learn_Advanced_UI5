<mvc:View
    controllerName="com.demo.learnui5.controller.View8"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:u="sap.ui.unified"
    xmlns:up="sap.m.upload"
>
    <Page
        title="i am View 8"
        showNavButton="true"
        navButtonPress="onNavBack"
    >
        <Panel
            headerText="Employee Create"
            backgroundDesign="Solid"
            accessibleRole="Region"
        >
            <f:SimpleForm
                id="oSFEmpCreate"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanL="2"
                labelSpanM="2"
                emptySpanL="8"
                emptySpanM="8"
            >
                <f:content>
                    <Label text="Employee Id" />
                    <Input id="oIpEmpIdC" />
                    <Label text="Name" />
                    <Input id="oIpNameC" />
                    <Label text="Deisgnation" />
                    <Input id="oIpDesigC" />
                    <Label text="Email" />
                    <Input id="oIpEmailC" />
                    <Label text="Status" />
                    <Input id="oIpStatusC" />
                    <Label text="Salary" />
                    <Input id="oIpSalaryC" />
                    <Label text="Rating" />
                    <Input id="oIpRatingC" />
                    <Label text="Upload your Photo"></Label>
                    <u:FileUploader 
                    id="oFileUploaderPhoto"
                    uploadUrl="/sap/opu/odata/sap/ZB78_EMP_SRV/PhotoSet"
                    sendXHR="true"
                    useMultipart="false"
                    change="onSelFile"
                    uploadComplete="onUploadComplete"
                    ></u:FileUploader>
                </f:content>
            </f:SimpleForm>
        </Panel>
        <Table
                id="oTabCert"
                items="{certModel>aCertifications}"
                class="sapUiSmallMargin"
                width="auto"
            >
                <headerToolbar>
                    <Toolbar>
                        <ToolbarSpacer />
                        <Button
                            press="onAddRow"
                            type="Emphasized"
                            icon="sap-icon://add"
                            text="Add Row"
                        />
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column>
                        <Text text="Employee Id" />
                    </Column>
                    <Column>
                        <Text text="Certificate Code" />
                    </Column>
                    <Column>
                        <Text text="Skill" />
                    </Column>
                    <Column>
                        <Text text="Certificate Name" />
                    </Column>
                    <Column>
                        <Text text="Delete" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <Input value="{certModel>Empid}" enabled="false" />
                        <Input value="{CertModel>Certcode}" />
                        <Input value="{CertModel>Skill}" />
                        <Input value="{CertModel>Certname}" />
                        <Button
                            icon="sap-icon://delete"
                            type="Reject"
                            press="onDeleteRow"
                        />
                    </ColumnListItem>
                </items>
            </Table>
        <Panel headerText="Upload Document">
         <up:UploadSet id="oUploadSet" instantUpload="false" multiple="true" uploadUrl="/sap/opu/odata/sap/ZB78_EMP_SRV/DocSet"
         uploadCompleted="onDocUploadCompleted">

        </up:UploadSet>
        </Panel>
        <footer>
            <Bar>
                <contentRight>
                    <Button
                        text="Save"
                        icon="sap-icon://save"
                        press="onPressSave"
                        type="Emphasized"
                    />
                </contentRight>
            </Bar>
        </footer>
    </Page>
</mvc:View>
