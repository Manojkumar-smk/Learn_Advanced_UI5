<mvc:View
    controllerName="com.demo.learnui5.controller.View7"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Page
        title="i am View 7"
        showNavButton="true"
        navButtonPress="onNavBack"
    >
        <content>
            <ObjectHeader
                title="{oModel>Name}"
                number="{oModel>Salary}"
                numberUnit="INR"
                icon="/sap/opu/odata/sap/ZB78_EMP_SRV/PhotoSet('{oModel>Empid}')/$value"
                imageShape="Circle"
                iconPress="onPressPhoto"
                iconActive="true"
            >
                <attributes>
                    <ObjectAttribute
                        title="Employee Id"
                        text="{oModel>Empid}"
                    />
                    <ObjectAttribute
                        title="Designation"
                        text="{oModel>Desig}"
                    />
                </attributes>
                <statuses>
                    <ObjectStatus text="{oModel>Status}" />
                </statuses>
            </ObjectHeader>
            <IconTabBar>
                <items>
                    <IconTabFilter icon="sap-icon://information">
                        <f:SimpleForm
                            id="oSFEmpDetails"
                            editable="false"
                        >
                            <f:content>
                                <Label text="Employee Id" />
                                <Text text="{oModel>Empid}" />
                                <Label text="Employee Name" />
                                <Text text="{oModel>Name}" />
                                <Label text="Designation" />
                                <Text text="{oModel>Desig}" />
                                <Label text="Salary" />
                                <Text text="{oModel>Salary}" />
                                <Label text="Status" />
                                <Text text="{oModel>Status}" />
                                <Label text="Rating" />
                                <Text text="{oModel>Rating}" />
                            </f:content>
                        </f:SimpleForm>
                    </IconTabFilter>
                    <IconTabFilter
                        icon="sap-icon://accounting-document-verification"
                    >
                        <Table items="{oModel>toCertifications}">
                            <columns>
                                <Column>
                                    <Text text="Employee Id" />
                                </Column>
                                <Column>
                                    <Text text="Certification Code" />
                                </Column>
                                <Column>
                                    <Text text="Skill" />
                                </Column>
                                <Column>
                                    <Text text="Description" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <Text text="{oModel>Empid}" />
                                    <Text text="{oModel>Certcode}" />
                                    <Text text="{oModel>Skill}" />
                                    <Text text="{oModel>Certname}" />
                                </ColumnListItem>
                            </items>
                        </Table>
                    </IconTabFilter>
                    <IconTabFilter icon="sap-icon://attachment">
                        <Table items="{oModel>toDocs}">
                            <columns>
                                <Column>
                                    <Text text="File Name" />
                                </Column>
                                <Column>
                                    <Text text="Download" />
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <Text text="{oModel>Filename}" />
                                    <Button
                                        icon="sap-icon://download"
                                        type="Reject"
                                        press="onDownloadFile"
                                    />
                                </ColumnListItem>
                            </items>
                        </Table>
                    </IconTabFilter>
                </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>
