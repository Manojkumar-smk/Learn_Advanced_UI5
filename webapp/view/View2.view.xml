<mvc:View
    controllerName="com.demo.learnui5.controller.View2"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Page
        title="i am View 2"
        showNavButton="true"
        navButtonPress="onNavBack"
    >
    <Panel expand="true" expandable="true" headerText="ObjectHeader">
        <ObjectHeader
            title="Manoj"
            number="230000"
            numberUnit="INR"
            numberState="Success"
            backgroundDesign="Solid"
            icon="sap-icon://employee"
        >
            <attributes>
                <ObjectAttribute
                    title="Employee ID"
                    text="10001"
                />
            </attributes>
            <statuses>
                <ObjectStatus
                    text="Available"
                    inverted="true"
                    state="Success"
                />
            </statuses>
        </ObjectHeader>
        </Panel>
        <Panel
            expandable="true"
            expanded="true"
            headerText="Employee Information"
        >
            <l:Grid
                vSpacing="0"
                defaultSpan="L12 M12"
            >
                <l:content>
                    <f:SimpleForm
                        editable="true"
                        labelSpanL="4"
                        labelSpanM="4"
                        emptySpanL="4"
                        emptySpanM="4"
                    >
                        <f:content>
                            <core:Title text="Basic Info" />
                            <Label text="Employee Id" />
                            <Input />
                            <core:Title text="Contact Info" />
                            <Label text="Mobile No" />
                            <Input />
                        </f:content>
                    </f:SimpleForm>
                </l:content>
            </l:Grid>
        </Panel>
        <Panel expand="true" expandable="true" headerText="Box">
        <content>
            <FlexBox justifyContent="Center">
                <VBox>
                    <Button text="VBoxDemo1" />
                    <HBox>
                        <Button text="HBoxBtn1" />
                        <Button text="VBoxDemo2" />
                    </HBox>
                </VBox>
                <Button text="FlexBoxBtn1" />
            </FlexBox>
        </content>
        </Panel>
        <Panel expand="true" expandable="true" headerText="Splitter">
        <content>
            <l:Splitter height="100px">
                <Button text="I am on Left" />
                <l:layoutData>
                    <l:SplitterLayoutData size="30%" />
                </l:layoutData>
                <Button text="I am on Right" />
            </l:Splitter>
        </content>
        </Panel>
    </Page>
</mvc:View>
