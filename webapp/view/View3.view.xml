<mvc:View
    controllerName="com.demo.learnui5.controller.View3"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Page
        title="i am View 3"
        showNavButton="true"
        navButtonPress="onNavBack"
    >
        <content>
            <Table items="{oModel>/EmployeeSet}">
                <headerToolbar>
                    <Toolbar>
                        <Title text="Employee Details" />
                    </Toolbar>
                </headerToolbar>
                <columns>
                    <Column>
                        <Text text="Employee ID" />
                    </Column>
                    <Column>
                        <Text text="Employee Name" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <Text text="{oModel>Empid}" />
                        <Text text="{oModel>Name}" />
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
