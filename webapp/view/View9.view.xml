<mvc:View
    controllerName="com.demo.learnui5.controller.View9"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Page
        title="i am View 9"
        showNavButton="true"
        navButtonPress="onNavBack"
    >
        <f:SimpleForm
            id="oSFEmpEdit"
            editable="false"
            title="Employee Details"
        >
            <f:content>
                <Label text="Employee Id" />
                <Input
                    id="oIpEmpIdE"
                    value="{oModel>Empid}"
                    enabled="false"
                />
                <Label text="Name" />
                <Input
                    id="oIpNameE"
                    value="{oModel>Name}"
                />
                <Label text="Deisgnation" />
                <Input
                    id="oIpDesigE"
                    value="{oModel>Desig}"
                />
                <Label text="Email" />
                <Input
                    id="oIpEmailE"
                    value="{oModel>Email}"
                />
                <Label text="Status" />
                <Input
                    id="oIpStatusE"
                    value="{oModel>Status}"
                />
                <Label text="Salary" />
                <Input
                    id="oIpSalaryE"
                    value="{oModel>Salary}"
                />
                <Label text="Rating" />
                <Input
                    id="oIpRatingE"
                    value="{oModel>Rating}"
                />
            </f:content>
        </f:SimpleForm>
        <Table items="{certUpdateModel>/results}">
            <headerToolbar>
                <Toolbar>
                    <Title text="Add/Edit Certification Details" />
                    <ToolbarSpacer />
                    <Button
                        icon="sap-icon://add"
                        type="Emphasized"
                        press="onPressAdd"
                    />
                </Toolbar>
            </headerToolbar>
            <columns>
                <Column>
                    <Text text="Employee Id" />
                </Column>
                <Column>
                    <Text text="Certification Code" />
                </Column>
                <Column>
                    <Text text="Skill" />
                </Column>
                <Column>
                    <Text text="Description" />
                </Column>
                <Column>
                    <Text text="Delete" />
                </Column>
            </columns>
            <items>
                <ColumnListItem>
                    <Input value="{certUpdateModel>Empid}" />
                    <Input value="{certUpdateModel>Certcode}" />
                    <Input value="{certUpdateModel>Skill}" />
                    <Input value="{certUpdateModel>Certname}" />
                    <Button
                        icon="sap-icon://delete"
                        type="Reject"
                        press="onDeleteRow"
                    />
                </ColumnListItem>
            </items>
        </Table>

        <footer>
            <Bar>
                <contentRight>
                    <Button
                        text="Save"
                        icon="sap-icon://save"
                        press="onPressSave"
                        type="Emphasized"
                    />
                </contentRight>
            </Bar>
        </footer>
    </Page>
</mvc:View>
