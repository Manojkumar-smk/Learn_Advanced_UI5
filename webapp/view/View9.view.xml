<mvc:View
    controllerName="com.demo.learnui5.controller.View9"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Page
        title="i am View 9"
        showNavButton="true"
        navButtonPress="onNavBack"
    >
        <Panel
            headerText="Employee Edit"
            backgroundDesign="Solid"
            expandable="true"
            expand="true"
        >
                <f:SimpleForm
                id="oSFEmpEdit"
                editable="false"
            >
                <f:content>
                <Label text="Employee Id"></Label>
          <Input id="oIpEmpIdE" value="{oModel>Empid}" enabled="false"></Input>
          <Label text="Name"></Label>
          <Input id="oIpNameE" value="{oModel>Name}"></Input>
          <Label text="Deisgnation"></Label>
          <Input id="oIpDesigE" value="{oModel>Desig}"></Input>
          <Label text="Email"></Label>
          <Input id="oIpEmailE" value="{oModel>Email}"></Input>
          <Label text="Status"></Label>
          <Input id="oIpStatusE" value="{oModel>Status}"></Input>
          <Label text="Salary"></Label>
          <Input id="oIpSalaryE" value="{oModel>Salary}"></Input>
          <Label text="Rating"></Label>
          <Input id="oIpRatingE" value="{oModel>Rating}"></Input>
                </f:content>
            </f:SimpleForm>
        </Panel>
        <footer>
            <Bar>
                <contentRight>
                    <Button
                        text="Save"
                        icon="sap-icon://save"
                        press="onPressSave"
                        type="Emphasized"
                    />
                </contentRight>
            </Bar>
        </footer>
    </Page>
</mvc:View>
